  "devDependencies": {
    "@types/node": "^24.13.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@yourssu-inhouse/eslint-config": "workspace:*",
    "@yourssu-inhouse/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.2",
    "typescript": "catalog:"
  },
  "dependencies": {
    "@yourssu-inhouse/inhouse-utils": "workspace:*",
    "es-toolkit": "^1.47.0",
    "immer": "^11.1.8",
    "react-simplikit": "^0.0.51"
