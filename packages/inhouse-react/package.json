{
  "name": "@yourssu-inhouse/inhouse-react",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./hooks": {
      "import": "./dist/hooks/index.mjs",
      "types": "./dist/hooks/index.d.ts"
    }
  },
  "scripts": {
