{
  "name": "@yourssu-inhouse/mfa-vite",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "check:type": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "fix:lint": "eslint . --fix",
    "fix:format": "prettier --write ."
  },
  "dependencies": {
    "@yourssu-inhouse/mfa-core": "workspace:*"
  },
  "devDependencies": {
    "@module-federation/vite": "^1.16.12",
    "@types/node": "^24.13.0",
    "@yourssu-inhouse/eslint-config": "workspace:*",
    "@yourssu-inhouse/typescript-config": "workspace:*",
    "eslint": "catalog:",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.2",
    "typescript": "catalog:",
    "vite": "^8.0.12"
  },
  "peerDependencies": {
    "@module-federation/vite": "^1.16.12",
    "vite": "^8.0.12"
  }
}
