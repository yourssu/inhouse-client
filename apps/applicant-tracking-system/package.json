{
  "name": "@yourssu-inhouse/applicant-tracking-system",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently 'vite' 'pnpm gen-color:watch'",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "check:type": "tsc --noEmit",
    "check:lint": "eslint .",
    "check:format": "prettier --check .",
    "fix:lint": "eslint . --fix",
    "fix:format": "prettier --write .",
    "gen-color": "pnpm tsx ./scripts/gen-color.ts",
    "gen-color:watch": "pnpm tsx watch --clear-screen=false --include ./src/styles/colors.css ./scripts/gen-color.ts",
    "fetch-schema": "pnpm tsx ./scripts/fetch-schema.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dismissable-layer": "^1.1.11",
