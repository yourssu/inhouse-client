    "@yourssu-inhouse/eslint-config": "workspace:*",
    "@yourssu-inhouse/typescript-config": "workspace:*",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "catalog:",
    "eslint-plugin-react-refresh": "^0.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vite": "^8.0.12",
    "vite-tsconfig-paths": "^6.1.1",
    "zx": "^8.8.5"
  }
