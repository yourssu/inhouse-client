    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-paragraph": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/extension-text-style": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@toss/lottie": "^1.3.2",
    "@yourssu-inhouse/interior": "workspace:*",
    "@yourssu-inhouse/interior-tailwind": "workspace:*",
    "@yourssu-inhouse/interior-vars": "workspace:*",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "es-hangul": "^2.3.8",
    "es-toolkit": "^1.44.0",
    "immer": "^11.1.3",
    "js-cookie": "^3.0.5",
    "ky": "^1.14.2",
    "motion": "^12.28.1",
    "overlay-kit": "^1.8.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-dropzone": "^15.0.0",
    "react-icons": "^5.5.0",
    "react-simplikit": "^0.0.46",
    "react-spinners": "^0.17.0",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "ts-pattern": "^5.9.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/router-plugin": "^1.153.2",
